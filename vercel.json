{
  "version": 2,
  "builds": [
    { "src": "api/index.js", "use": "@vercel/node" },
    { "src": "dist/client/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/assets/(.*)", "dest": "/dist/client/assets/$1" },
    { "src": "/(.*\\.js)", "dest": "/dist/client/$1" },
    { "src": "/(.*\\.css)", "dest": "/dist/client/$1" },
    { "src": "/(.*)", "dest": "/api/index.js" }
  ]
}
